# raph-server-installer — top-level installer environment.
#
# This file documents EVERY environment variable the installer accepts.
# Copy to /opt/stacks/.env on the VPS at install time (bootstrap.sh writes
# this from the operator-supplied DOMAIN/ADMIN_EMAIL plus generated values).
# The file is gitignored on real installs; only this example is committed.
#
# Variables marked REQUIRED have no default; the installer fails loudly if
# they are unset. Variables marked OPTIONAL have a sensible default that
# only needs overriding to deviate from the standard installer flow.

# ──────────────────────────────────────────────────────────────────────────
# Phase 1 — operator inputs (from the LayerStack User-Data box)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED. The apex domain the installer is hosting on. All user-facing
# subdomains derive from this: auth.${DOMAIN}, cloud.${DOMAIN},
# enrol.${DOMAIN}, console.${DOMAIN}, gw.${DOMAIN}, cdn.${DOMAIN},
# setup.${DOMAIN}.
DOMAIN=example.com

# REQUIRED. Used as the Let's Encrypt contact for the wildcard cert and
# pre-populated into the wizard's admin-email field.
ADMIN_EMAIL=admin@example.com

# ──────────────────────────────────────────────────────────────────────────
# Phase 1 — host hardening (bootstrap-host.sh, install-docker.sh)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED at host-bootstrap time. Whitespace-separated list of admin
# usernames to create as NOPASSWD-sudo OS users. The wizard typically
# supplies a single name (the bootstrap admin).
ADMIN_USERS=alice

# REQUIRED at host-bootstrap time. Same list rendered into sshd's
# AllowUsers directive in 99-hardening.conf.template.
ADMIN_USERS_SSH=alice

# ──────────────────────────────────────────────────────────────────────────
# Phase 1 — gateway (install-gw0.sh, provision-peer.sh)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. AmneziaWG public endpoint embedded in client peer .conf files.
# Default derived from $DOMAIN: gw.${DOMAIN}:443
# AWG_ENDPOINT=gw.example.com:443

# OPTIONAL. AmneziaWG peer subnet.
# PEER_SUBNET=10.99.0.0/24

# OPTIONAL. First host octet for new peers (low octets reserved).
# PEER_START=10

# ──────────────────────────────────────────────────────────────────────────
# Phase 2 — wizard / setup mode (consumed by stacks/enrol)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED inside the enrol container. Apex domain for Authelia logout
# link, launcher tile URLs, and the auth-portal redirect message.
ENROL_DOMAIN=example.com

# OPTIONAL. AmneziaWG endpoint advertised to clients (defaults to
# gw.${ENROL_DOMAIN}:443 if unset).
# ENROL_AWG_ENDPOINT=gw.example.com:443

# ──────────────────────────────────────────────────────────────────────────
# Phase 2 — DNS provider (cert issuance via NPM)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. Currently only "ovh" is fully wired. Documents which DNS
# provider the wizard should configure for the DNS-01 wildcard cert.
# DNS_PROVIDER=ovh

# REQUIRED for OVH DNS-01. Pasted into NPM's "Credentials File Content"
# field at cert-creation time. Generated at https://auth.eu.ovhcloud.com/api/createToken
# (CA: https://auth.ca.ovhcloud.com/api/createToken; US:
# https://api.us.ovhcloud.com/createToken/), scoped to the single zone.
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=replace-me
OVH_APPLICATION_SECRET=replace-me
OVH_CONSUMER_KEY=replace-me

# ──────────────────────────────────────────────────────────────────────────
# Phase 2 — NPM bootstrap admin (wire-npm-routes.sh)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED to wire the four proxy hosts (auth, enrol, cloud, console).
# These are NPM's first-boot defaults; the wizard rotates them
# immediately after the API session is established. Never reuse these
# values for anything else.
NPM_EMAIL=admin@example.com
NPM_PASS=changeme

# ──────────────────────────────────────────────────────────────────────────
# Authelia secrets — generated by the wizard, NOT operator-supplied
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED at render time. The pbkdf2-sha512 digest of the OIDC client
# secret used by Portainer (`console`). The plaintext goes into Portainer's
# UI; the hash goes here. Generated by the wizard.
AUTHELIA_OIDC_CONSOLE_CLIENT_SECRET_HASH=$pbkdf2-sha512$REPLACE_ME

# REQUIRED at render time. The pbkdf2-sha512 digest of the OIDC client
# secret used by Nextcloud (`cloud`). The plaintext goes into Nextcloud's
# user_oidc app config; the hash goes here. Generated by the wizard
# (bootstrap.sh stamps a placeholder; scripts/oidc rotates the real value).
AUTHELIA_OIDC_CLOUD_CLIENT_SECRET_HASH=$pbkdf2-sha512$REPLACE_ME

# REQUIRED at render time. The pbkdf2-sha512 digest of the OIDC client
# secret used by Plane (`plane`). The plaintext goes into Plane's OIDC
# config; the hash goes here. Generated by the wizard (bootstrap.sh
# stamps a placeholder; scripts/oidc rotates the real value).
AUTHELIA_OIDC_PLANE_CLIENT_SECRET_HASH=$pbkdf2-sha512$REPLACE_ME

# ──────────────────────────────────────────────────────────────────────────
# Phase 3 — qedge (alternate ingress; off by default)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED only if qedge is started. Hysteria2 obfuscation password.
# Wizard generates and seals this off-host; the runtime config is
# rendered from stacks/qedge/config.yaml.template.
QEDGE_PASSWORD=replace-me

# ──────────────────────────────────────────────────────────────────────────
# Backups — laptop-side (NOT installed on the VPS)
# ──────────────────────────────────────────────────────────────────────────

# Restic repo password. Lives only on the admin's laptop, NEVER on the
# VPS. Documented here so operators have a checklist of every variable
# the system uses end-to-end. See docs/backups.md for setup.
# RESTIC_PASSWORD=<set in laptop's password manager, never on VPS>

# ──────────────────────────────────────────────────────────────────────────
# Smoke-test (scripts/smoke-test.sh) — laptop-side only
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED when running smoke-test.sh. The VPS hostname/IP and the SSH
# login admin to use.
# VPS_HOST=vps.example.com
# VPS_USER=alice

# OPTIONAL. The expected public IPv4 the apex/wildcard records should
# resolve to. If unset, smoke-test skips DNS-IP equality assertions and
# only checks that something resolves.
# EXPECTED_IP=

# OPTIONAL. Path to the chnroutes cache file on the VPS.
# CHNROUTES_PATH=/var/cache/raph/chnroutes.txt
