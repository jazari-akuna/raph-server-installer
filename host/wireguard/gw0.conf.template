# gw0 — gateway server config template.
#
# Rendered by scripts/install-gw0.sh into /etc/amnezia/amneziawg/gw0.conf
# with the generated server private key and randomized magic-header values
# substituted at install time. Peers are appended later by
# scripts/provision-peer.sh; do not hand-edit rendered conf on the server
# (see claude-readme.md: server fs is reproducible from this repo).
#
# IMPORTANT: do NOT write literal placeholder syntax (the dollar-brace VAR
# pattern) anywhere in this comment block or in any other comment. The
# install script sed-substitutes those tokens globally, including in
# comments — so any literal placeholder text ends up holding secret values
# in the rendered file.

[Interface]
# Server private key — generated by install-gw0.sh, never committed.
PrivateKey = ${SERVER_PRIVATE_KEY}

# RFC1918 /24 private to the gateway. .1 is the server; peers get .2+.
Address = 10.99.0.1/24

# UDP listen port. Matches ufw allow rule staged in bootstrap-host.sh.
ListenPort = 51820

# 1380 leaves headroom under the typical 1500-byte path MTU once the
# AmneziaWG header (variable, larger than vanilla WG due to junk) is added.
# Tune downward only if PMTUD black-holes are observed.
MTU = 1380

# NAT MASQUERADE for 10.99.0.0/24 lives in /etc/ufw/before.rules (see
# host/ufw/before.rules.fragment), spliced once at install time. That keeps
# the NAT rule under ufw's reload model instead of fighting it from PostUp.
# PostUp/PostDown are intentionally empty — nothing per-up needs to toggle.
# PostUp =
# PostDown =

# --- AmneziaWG anti-DPI parameters --------------------------------------
# Junk-packet count: how many bogus packets to send at handshake start.
Jc = 4
# Junk-packet min size (bytes).
Jmin = 40
# Junk-packet max size (bytes).
Jmax = 70
# Init-packet prefix junk size — prepends garbage to the WG init packet.
S1 = 50
# Response-packet prefix junk size — prepends garbage to the WG response.
S2 = 100
# Randomized "magic header" uint32s; replace WG's fixed type bytes so the
# first four bytes of each packet type don't match a known WG signature.
# install-gw0.sh fills these from /dev/urandom on first render.
H1 = ${H1}
H2 = ${H2}
H3 = ${H3}
H4 = ${H4}

