# /opt/stacks/authelia/.env — secret material. Mode 0600 root:root on the VPS.
#
# This .example is committed; the real .env is gitignored.
# All five values are 64+ random bytes generated at deploy time. The OIDC
# issuer private key lives in secrets/oidc-key.pem (separate file because
# multi-line PEMs in .env are a footgun).
#
# Generate at deploy:
#   for f in jwt-secret session-secret storage-encryption-key oidc-hmac-secret; do
#     openssl rand -base64 64 | tr -d '\n' | sudo tee /opt/stacks/authelia/secrets/$f >/dev/null
#     sudo chmod 0600 /opt/stacks/authelia/secrets/$f
#   done
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out /tmp/oidc.pem \
#     && openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in /tmp/oidc.pem \
#       | sudo tee /opt/stacks/authelia/secrets/oidc-key.pem >/dev/null \
#     && sudo chmod 0600 /opt/stacks/authelia/secrets/oidc-key.pem \
#     && shred -u /tmp/oidc.pem
#
# The pbkdf2 client-secret hash for Portainer is templated into
# configuration.yml from this env var. Generate plaintext + hash with:
#   PORTAINER_CLIENT_SECRET="$(openssl rand -hex 32)"
#   docker run --rm authelia/authelia:4.39.19 \
#     authelia crypto hash generate pbkdf2 --variant sha512 \
#     --password "$PORTAINER_CLIENT_SECRET"
# Save the plaintext for the Portainer UI; put the hash here.

# Replace REPLACE_ME with the real pbkdf2-sha512 digest from
# `authelia crypto hash generate pbkdf2 --variant sha512 --password ...`.
# The hash starts with a literal $ and contains many $-delimited segments
# — keep them as a single unbroken string (no quotes, no spaces).
AUTHELIA_OIDC_CONSOLE_CLIENT_SECRET_HASH=REPLACE_ME_WITH_PBKDF2_HASH
