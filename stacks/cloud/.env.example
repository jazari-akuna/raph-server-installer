# stacks/cloud/.env.example
#
# Copy to `.env` on the VPS (mode 0600) and fill in real argon2 hashes.
# `.env` is gitignored — never commit real hashes. The values below are
# obvious placeholders, not valid hashes; copyparty will refuse to start
# until they are replaced.
#
# ----------------------------------------------------------------------
# Generating an argon2 password hash
# ----------------------------------------------------------------------
# copyparty ships an interactive hasher behind the `--ah-cli` flag. Run
# it inside a throwaway copyparty/ac container so the algorithm and
# version match the running service exactly:
#
#     docker run --rm -it copyparty/ac:1.20.14 \
#         --ah-alg argon2 --ah-cli
#
# It prompts for a password (twice), prints a single line of the form
#   +<algo>$<params>$<salt>$<hash>
# Copy that entire line — including the leading `+` — into the matching
# variable below. Repeat for each user. The hash is salted and slow;
# leaking it is far less damaging than leaking a plaintext password,
# but treat the .env file like a secret regardless (mode 0600, never
# checked in, never pasted into chat).
#
# Note: the hashing algorithm used here MUST match `ah-alg:` in
# conf/copyparty.conf (currently argon2). If you change the algorithm,
# regenerate every hash.

SAGAN_PW_HASH=replace-me-with-argon2-hash-for-sagan
MARCUS_PW_HASH=replace-me-with-argon2-hash-for-marcus
