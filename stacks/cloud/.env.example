# stacks/cloud/.env.example — template for the cloud stack's environment.
#
# Copy to /opt/stacks/cloud/.env on the VPS at install time. The actual
# .env is generated by bootstrap-phase2.sh (Postgres password and admin
# password are random per install) and is gitignored. This file documents
# every variable the cloud stack reads at compose-up time.
#
# Variables marked REQUIRED have no default — `docker compose up` fails
# loudly if they are unset. Variables marked OPTIONAL have a sensible
# default that only needs overriding for non-standard installs.

# ──────────────────────────────────────────────────────────────────────────
# Database — Postgres 16 (cloud-db service)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED. Random password for the Nextcloud Postgres role. Generated
# by bootstrap-phase2.sh (`openssl rand -base64 32` style) and persisted
# here. Used by both cloud-db (to initialize the role on first start)
# and cloud (to connect). Never reuse across installs.
POSTGRES_PASSWORD=

# OPTIONAL. Postgres role + database name. Defaults match the
# nextcloud-fpm image's expectations and there is no reason to change
# them — leaving these unset is the supported path.
POSTGRES_USER=nextcloud
POSTGRES_DB=nextcloud

# ──────────────────────────────────────────────────────────────────────────
# Nextcloud bootstrap admin (only used on the very first `compose up`)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. Admin username created on first install. Subsequent runs
# ignore this — admin lifecycle moves to occ / the web UI / OIDC.
NEXTCLOUD_ADMIN_USER=nadmin

# REQUIRED. Random admin password generated by bootstrap-phase2.sh.
# Surfaced once to the operator at the end of finalize so they can log
# in pre-OIDC and bootstrap the user_oidc app. Rotate (or delete the
# admin user altogether) once OIDC SSO is operational.
NEXTCLOUD_ADMIN_PASSWORD=

# REQUIRED. Comma-separated list of Host header values Nextcloud will
# accept. Anything not on this list is rejected with "You are accessing
# the server from an untrusted domain". Templated to cloud.${DOMAIN}
# by render-templates.sh during bootstrap; the example value below is
# what the wizard uses on a fresh install.
NEXTCLOUD_TRUSTED_DOMAINS=cloud.example.com

# ──────────────────────────────────────────────────────────────────────────
# Redis — cloud-redis service
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. Hostname Nextcloud uses to reach Redis. Defaults to the
# in-stack service name and there is no reason to change it for a
# normal install.
REDIS_HOST=cloud-redis
