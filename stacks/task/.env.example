# stacks/plane/.env.example — template for the plane stack's environment.
#
# Copy to /opt/stacks/plane/.env on the VPS at install time. The actual
# .env is generated by bootstrap-phase2.sh (Postgres password, RabbitMQ
# password, MinIO root password, Django secret key, live-server secret
# are all random per install) and is gitignored. This file documents
# every variable the plane stack reads at compose-up time.
#
# Variables marked REQUIRED have no default — `docker compose up` fails
# loudly (`:?` validators in docker-compose.yml) if they are unset.
# Variables marked OPTIONAL have a sensible default that only needs
# overriding for non-standard installs.

# ──────────────────────────────────────────────────────────────────────────
# Domain — what Plane thinks its public URL is
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. The hostname Plane uses to construct self-referential URLs
# (e.g. notification email links, OIDC redirect_uri suggestions in
# god-mode). Templated to plane.${DOMAIN} by render-templates.sh during
# bootstrap.
APP_DOMAIN=plane.example.com

# OPTIONAL. The full public-facing URL Plane uses for callbacks +
# attachment URLs. Must include the scheme. Plane's API also gates CSRF
# against this value.
WEB_URL=https://plane.example.com

# OPTIONAL. CORS allow-list for the API. Comma-separated list of full
# origins. Must at least include WEB_URL. If you add the Plane mobile
# app or a separate frontend, append its origin here.
CORS_ALLOWED_ORIGINS=https://plane.example.com

# ──────────────────────────────────────────────────────────────────────────
# Database — Postgres 15 (plane-db service)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED. Random password for the Plane Postgres role. Generated by
# bootstrap-phase2.sh (`openssl rand -base64 32` style) and persisted
# here. Used by both plane-db (to initialize the role on first start)
# and plane-api/worker/beat/migrator (to connect via DATABASE_URL).
# Never reuse across installs.
POSTGRES_PASSWORD=

# OPTIONAL. Postgres role + database name. Defaults match upstream
# Plane's expectations and there is no reason to change them — leaving
# these unset is the supported path.
POSTGRES_USER=plane
POSTGRES_DB=plane

# ──────────────────────────────────────────────────────────────────────────
# RabbitMQ — Celery broker (plane-mq service)
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED. Random password for the RabbitMQ admin / Celery user.
# Generated by bootstrap-phase2.sh. Used by plane-mq (to initialize the
# user on first start) and by plane-api/worker/beat (via AMQP_URL).
RABBITMQ_DEFAULT_PASS=

# OPTIONAL. RabbitMQ user + vhost name. Both default to `plane`. Don't
# change unless you're sharing the broker (which we explicitly don't —
# see ADR-008).
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_VHOST=plane

# ──────────────────────────────────────────────────────────────────────────
# MinIO — S3-compatible attachment store (plane-minio service)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. The S3 access-key-id Plane talks to MinIO with. Acts as the
# MinIO root user too (MINIO_ROOT_USER in plane-minio's env). Defaults
# to `plane` — there is no reason to change this for an install with
# only Plane talking to this MinIO.
AWS_ACCESS_KEY_ID=plane

# REQUIRED. Random secret-key Plane authenticates to MinIO with. Acts
# as MINIO_ROOT_PASSWORD too. Generated by bootstrap-phase2.sh
# (`openssl rand -base64 32`-equivalent). Loss = re-issue + restart
# both plane-minio and every backend container.
AWS_SECRET_ACCESS_KEY=

# OPTIONAL. The S3 bucket name Plane writes attachments into. The
# plane-mc one-shot creates this on first up. Default `uploads` matches
# upstream Plane.
AWS_S3_BUCKET_NAME=uploads

# OPTIONAL. AWS region — only meaningful if you point Plane at real S3
# instead of MinIO (you're not). Leave empty.
AWS_REGION=

# ──────────────────────────────────────────────────────────────────────────
# Django / API secrets
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED. Django SECRET_KEY (signs session cookies, password reset
# tokens, etc). Must be at least 32 chars; 64 chars recommended.
# Generated by bootstrap-phase2.sh as `openssl rand -base64 48`.
# Rotation invalidates all existing session cookies (forces every user
# to re-login) but does NOT invalidate API tokens. Never commit.
SECRET_KEY=

# REQUIRED. Shared secret between plane-live (the WebSocket server)
# and plane-api so live can verify request origins from the API
# without a full auth round-trip. Generated by bootstrap-phase2.sh as
# `openssl rand -base64 32`. Upstream's default is a hardcoded
# 32-char string committed to the repo — DO NOT use that in production.
LIVE_SERVER_SECRET_KEY=

# OPTIONAL. Per-token rate limit for /api/v1/* endpoints. Format:
# `<count>/<unit>` where unit is `second`, `minute`, `hour`, `day`.
# Default 60/minute is fine for the enrol admin page's polling.
API_KEY_RATE_LIMIT=60/minute

# ──────────────────────────────────────────────────────────────────────────
# Resource tuning knobs (ADR-008)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. Number of Celery worker processes. Default upstream is
# `auto` = one per CPU core. On a 2 GB / 2 vCPU VPS that's ~400 MB
# just for workers; cap to 1 to fit the budget.
CELERY_WORKER_CONCURRENCY=1

# OPTIONAL. gunicorn worker count for plane-api. Default 1 (Plane
# upstream also defaults to 1, but documents it as the knob to raise
# when API is CPU-bound). Each additional worker is ~150 MB RSS.
GUNICORN_WORKERS=1

# ──────────────────────────────────────────────────────────────────────────
# Misc Plane knobs (rarely changed)
# ──────────────────────────────────────────────────────────────────────────

# OPTIONAL. Maximum upload size in BYTES Plane will accept on the API
# side (separate from NPM's `client_max_body_size`, which gates earlier
# in the chain). Default 5 GB matches NPM's `client_max_body_size 5G`
# in npmAdvPlaneTmpl (stacks/enrol/setup.go); if you change either,
# change both.
FILE_SIZE_LIMIT=5368709120
