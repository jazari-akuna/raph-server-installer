#!/usr/bin/env bash
# Stub `cryptsetup`. Bootstrap's TEST_MODE branch in create-shared-volume.sh
# already short-circuits cryptsetup luksFormat / open / close. This stub
# catches any leaked invocation and logs it.
set -uo pipefail
LOG="${TEST_STUB_LOG:-/tmp/test-stubs.log}"
printf 'cryptsetup %s\n' "$*" >> "$LOG"

case "${1:-}" in
  luksFormat|open|close)
    # Leaked: production code should never call these in TEST_MODE.
    echo "STUB-cryptsetup-leak: real cryptsetup invoked in TEST_MODE: $*" >&2
    exit 0
    ;;
  status|isLuks)
    exit 0
    ;;
esac
exit 0
