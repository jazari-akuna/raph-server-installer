# raph-server-installer — do not commit secrets, peer configs, or rendered templates.
#
# Anything generated at runtime (peer configs, certs, hashed secrets,
# rendered .conf files from .template, restic repo metadata) MUST stay
# out of version control. This file is the single authoritative list.

# Per-device peer configs are generated by scripts/provision-peer.sh.
# They contain private keys; never commit them.
peers/

# Secrets and key material
*.key
*.crt
*.pem
*.env
.env
.env.*
!.env.example
# Do NOT use a blanket `secrets/` because it forecloses re-including
# .gitkeep stubs in committed stack scaffolding (see authelia/secrets/).
# Specific paths are listed in their respective stack sections below.

# Generated artifacts
*.img
*.qr.png

# Authelia: rendered configuration.yml (from .template) + users db + state.
# Only the .template, .example, and DESIGN.md are committed.
stacks/authelia/configuration.yml
stacks/authelia/users_db/users_database.yml
stacks/authelia/data/*
!stacks/authelia/data/.gitkeep
stacks/authelia/secrets/*
!stacks/authelia/secrets/.gitkeep

# host/ssh/keys/ is operator-supplied at install time. We never commit
# anyone's actual public keys.
host/ssh/keys/

# Rendered host configs (templates -> real files done by render-templates.sh).
host/ssh/sshd_config.d/99-hardening.conf

# Rendered NPM/Authelia snippets (templates -> real files done by
# render-templates.sh).
stacks/authelia/snippets/authelia-authrequest.conf

# Rendered qedge config (template -> real file done by render-templates.sh).
stacks/qedge/config.yaml

# enrol: persisted runtime data (not produced under repo, but defensive)
stacks/enrol/data/

# cloud / console: copyparty + Portainer runtime state
stacks/cloud/data/
stacks/console/data/

# Working-notes journals — wave-1a, wave-1b, etc. Local to the operator
# running the wave; not meant to be shared.
.journals/

# Test harness runtime artefacts (built image logs, container.log,
# per-scenario phase{1,2} captures). Created by tests/run-tests.sh.
tests/.last-run/

# Node tooling, if it shows up later (none currently committed).
node_modules/

# Editor / OS noise
.DS_Store
*.swp
*.swo
.vscode/
.idea/
